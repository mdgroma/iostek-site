# Variabili d'ambiente iostek-site (Next.js)
# Copia in .env.local (sviluppo) o configura nel pannello di hosting (produzione).

# Resend — invio email del modulo di contatto.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Destinatario delle richieste del modulo (default: marco@iostek.com)
CONTACT_TO=marco@iostek.com

# Mittente verificato su Resend per il dominio iostek.com
# (verifica iostek.com in Resend, poi usa un indirizzo @iostek.com)
CONTACT_FROM=iOStek <noreply@iostek.com>
