# Variabili d'ambiente iostek-site (Next.js)
# Copia in .env.local (sviluppo) o configura nel pannello di hosting (produzione).

# Resend — invio email del modulo di contatto.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Destinatario delle richieste del modulo (default: marco@iostek.com)
CONTACT_TO=marco@iostek.com

# Mittente verificato su Resend per il dominio iostek.com
# (verifica iostek.com in Resend, poi usa un indirizzo @iostek.com)
CONTACT_FROM=iOStek <noreply@iostek.com>

# Umami — analytics cookieless e privacy-friendly. Lo script viene incluso solo
# se entrambe le variabili sono valorizzate. Lascia vuoto per disabilitarlo.
# SRC: con Umami Cloud è https://cloud.umami.is/script.js (oppure l'URL della tua
# istanza self-hosted, es. https://analytics.iostek.com/script.js).
# WEBSITE_ID: l'ID del sito che trovi nelle impostazioni di Umami.
NEXT_PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
